                                        Padding="12,6"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="2"
                                        Content="Copy output"
                                        Command="{Binding Editor.CopyDiagnosticOutputCommand}"
                                        Padding="12,6" />
                            </Grid>

                            <TextBox Grid.Row="4"
                                     Text="{Binding Editor.DiagnosticText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Height="190"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" />

                            <Grid Grid.Row="5" Margin="0,10,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Editor.DiagnosticHistorySummary}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Editor.DiagnosticLogPathDisplay}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Copy log path"
                                        Command="{Binding Editor.CopyDiagnosticLogPathCommand}"
                                        Padding="12,6"
                                        Margin="10,0,0,0" />
                            </Grid>

                            <DataGrid Grid.Row="6"
                                      ItemsSource="{Binding Editor.DiagnosticHistory}"
                                      SelectedItem="{Binding Editor.SelectedDiagnosticHistoryItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      Height="118">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time"
                                                        Binding="{Binding CompletedAtText}"
                                                        Width="92" />
                                    <DataGridTextColumn Header="Diagnostic"
                                                        Binding="{Binding Name}"
                                                        Width="138" />
                                    <DataGridTextColumn Header="Status"
                                                        Binding="{Binding StatusLabel}"
                                                        Width="62" />
                                    <DataGridTextColumn Header="Duration"
                                                        Binding="{Binding DurationText}"
                                                        Width="72" />
                                    <DataGridTextColumn Header="Preview"
                                                        Binding="{Binding OutputPreview}"
                                                        Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Reticle Aim">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,14,0,0">

                    <TextBlock Text="Reticle Aim Mode"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,6,0,8" />
                    <Border Style="{StaticResource RaisedBlockStyle}">
                        <CheckBox Content="Enable reticle aim"
                                  IsChecked="{Binding Editor.MouseAimEnabled, Mode=TwoWay}"
                                  Style="{StaticResource EditorCheckBoxStyle}" />
                    </Border>

                    <TextBlock Text="Reticle Aim Basic"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0,6,0,8"
                               Visibility="{Binding Editor.IsMouseAimMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Border Style="{StaticResource RaisedBlockStyle}"
                            IsEnabled="{Binding Editor.IsMouseAimMode}"
                            Visibility="{Binding Editor.IsMouseAimMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sensitivity X" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Editor.AimSensitivityX, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Sensitivity Y" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Editor.AimSensitivityY, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Slew rate" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding Editor.AimSlewRate, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Reticle limit" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Editor.AimReticleLimit, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Deadband" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Editor.AimReticleDeadband, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="Return" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding Editor.AimReturnRate, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Roll gain" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Editor.AimRollGain, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Yaw gain" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Editor.AimYawGain, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="Pitch gain" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding Editor.AimPitchGain, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Roll max" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Editor.AimRollMax, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Yaw max" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding Editor.AimYawMax, UpdateSourceTrigger=LostFocus}" Style="{StaticResource EditorTextBoxStyle}" />
                            <WrapPanel Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2">
                                <CheckBox Content="Invert X" IsChecked="{Binding Editor.AimInvertX, Mode=TwoWay}" Style="{StaticResource EditorCheckBoxStyle}" />
                                <CheckBox Content="Invert Y" IsChecked="{Binding Editor.AimInvertY, Mode=TwoWay}" Style="{StaticResource EditorCheckBoxStyle}" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Catalog">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,14,0,0">

                    <TextBlock Text="Settings Catalog" Style="{StaticResource SectionTitleStyle}" Margin="0,6,0,8" />
                    <Border Style="{StaticResource RaisedBlockStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Editor.CatalogSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search labels, TOML key names, groups, pages, and current values." />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Editor.CatalogSummary}"
                                           Style="{StaticResource MutedTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </Grid>

                            <WrapPanel Margin="0,0,0,10">
                                <CheckBox Content="Basic"
                                          IsChecked="{Binding Editor.ShowBasicSettings, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}" />
                                <CheckBox Content="Advanced"
                                          IsChecked="{Binding Editor.ShowAdvancedSettings, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}" />
                                <CheckBox Content="Tuning"
                                          IsChecked="{Binding Editor.ShowExperimentalSettings, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}" />
                                <CheckBox Content="Changed only"
                                          IsChecked="{Binding Editor.ShowChangedSettingsOnly, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}" />
                                <CheckBox Content="Invalid only"
                                          IsChecked="{Binding Editor.ShowInvalidSettingsOnly, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}" />
                            </WrapPanel>

                            <DataGrid ItemsSource="{Binding Editor.CatalogRowsView}"
                                      SelectedItem="{Binding Editor.SelectedCatalogRow, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      Height="420">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tier"
                                                        Binding="{Binding TierLabel}"
                                                        Width="86" />
                                    <DataGridTextColumn Header="Group"
                                                        Binding="{Binding Group}"
                                                        Width="160" />
                                    <DataGridTemplateColumn Header="Setting" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           ToolTipService.ShowDuration="30000">
                                                    <TextBlock.ToolTip>
                                                        <ToolTip Background="{StaticResource BgRaisedBrush}"
                                                                 BorderBrush="{StaticResource AccentBrush}"
                                                                 BorderThickness="1"
                                                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                 MaxWidth="300">
                                                            <StackPanel Margin="11">
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           Margin="0,0,0,5" />
                                                                <TextBlock Text="{Binding Help}"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock Text="{Binding DetailText}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Visibility="{Binding HasDetailText, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock Text="{Binding RiskText}"
                                                                           Foreground="{StaticResource WarnBrush}"
                                                                           Visibility="{Binding HasRiskText, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                           Margin="0,0,0,6" />
                                                                <TextBlock Text="{Binding TomlPath}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource InfoBrush}"
                                                                           Margin="0,0,0,7" />
                                                                <Image Source="{Binding TooltipImagePath}"
                                                                       MaxWidth="180"
                                                                       MaxHeight="140"
                                                                       Stretch="Uniform"
                                                                       Visibility="{Binding HasTooltipImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                       Margin="0,0,0,7" />
                                                                <TextBlock Text="{Binding TooltipImageStatus}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </TextBlock.ToolTip>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="TOML"
                                                        Binding="{Binding TomlPath}"
                                                        Width="190" />
                                    <DataGridTextColumn Header="Value"
                                                        Binding="{Binding DisplayValue}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Default"
                                                        Binding="{Binding DefaultDisplayValue}"
                                                        Width="105" />
                                    <DataGridTextColumn Header="Status"
                                                        Binding="{Binding StatusLabel}"
                                                        Width="84" />
                                    <DataGridTextColumn Header="Image"
                                                        Binding="{Binding TooltipImageBadge}"
                                                        Width="64" />
                                    <DataGridTemplateColumn Header="Jump" Width="72">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Go"
                                                        Padding="7,3"
                                                        MinHeight="0"
                                                        Command="{Binding DataContext.Editor.JumpToCatalogRowCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="{Binding Editor.CatalogJumpText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,8,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Selected Profile TOML" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBox Text="{Binding Editor.RawTomlText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             Height="220"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="NoWrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Catalog Detail" Style="{StaticResource SectionTitleStyle}" />
                                    <Border Background="#181D20"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            MinHeight="220">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Editor.SelectedCatalogLabel}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Editor.CatalogJumpText}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,5,0,8" />
                                            <TextBlock Text="{Binding Editor.SelectedCatalogHelp}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <Grid IsEnabled="{Binding Editor.IsCatalogEditEnabled}"
                                                  Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Editor.CatalogEditValue, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Edit the selected setting value. String and enum values are saved as TOML strings automatically." />
                                                <Button Grid.Column="1"
                                                        Content="Apply"
                                                        Command="{Binding Editor.ApplyCatalogValueCommand}"
                                                        Padding="12,6"
                                                        Margin="8,0,0,0" />
                                                <Button Grid.Column="2"
                                                        Content="Default"
                                                        Command="{Binding Editor.ResetCatalogValueCommand}"
                                                        Padding="12,6"
                                                        Margin="8,0,0,0" />
                                            </Grid>
                                            <TextBlock Text="{Binding Editor.SelectedCatalogDetail}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,0,0,5" />
                                            <TextBlock Text="{Binding Editor.SelectedCatalogAllowedValues}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,0,0,5" />
                                            <TextBlock Text="{Binding Editor.SelectedCatalogRawValue, StringFormat=Raw: {0}}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding Editor.TooltipImageStatus}"
                                                       Foreground="{StaticResource WarnBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <Border Background="#101416"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8"
                                                    HorizontalAlignment="Left"
                                                    Visibility="{Binding Editor.HasSelectedTooltipImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Image Source="{Binding Editor.SelectedTooltipImagePath}"
                                                       MaxWidth="180"
                                                       MaxHeight="140"
                                                       Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="{Binding Editor.SelectedTooltipImageDisplayPath}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Files">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,14,0,0">

                    <TextBlock Text="App Settings" Style="{StaticResource SectionTitleStyle}" Margin="0,6,0,8" />
                    <Border Style="{StaticResource RaisedBlockStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="UI settings" Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                                       Text="{Binding Editor.UiSettingsFilePath}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Setting tooltip images" Style="{StaticResource FieldLabelStyle}" Margin="0,8,8,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4"
                                       Text="{Binding Editor.TooltipImageDirectory}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,8,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Random sprites" Style="{StaticResource FieldLabelStyle}" Margin="0,8,8,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Editor.TooltipSpriteDirectory}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,8,0,0" />
                            <Button Grid.Row="2" Grid.Column="2"
                                    Content="Copy folder"
                                    Command="{Binding Editor.CopyTooltipSpriteDirectoryCommand}"
                                    Padding="12,6"
                                    Margin="10,8,0,0" />
                            <Button Grid.Row="2" Grid.Column="3"
                                    Content="Refresh"
                                    Command="{Binding Editor.RefreshTooltipSpritesCommand}"
                                    Padding="12,6"
                                    Margin="8,8,0,0" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Asuka sprite" Style="{StaticResource FieldLabelStyle}" Margin="0,8,8,0" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox Content="Random return"
                                          IsChecked="{Binding Editor.AboveBarSpriteRandomReturnDelay, Mode=TwoWay}"
                                          Style="{StaticResource EditorCheckBoxStyle}"
                                          ToolTip="Controls whether the Asuka sprite return delay is random or fixed." />
                                <TextBlock Text="Fixed seconds"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Margin="4,0,8,8" />
                                <TextBox Text="{Binding Editor.AboveBarSpriteFixedReturnDelaySecondsText, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource EditorTextBoxStyle}"
                                         Width="88"
                                         IsEnabled="{Binding Editor.IsAboveBarSpriteFixedReturnDelayEnabled}"
                                         ToolTip="Seconds to wait before the Asuka sprite returns when random return is off." />
                                <TextBlock Text="{Binding Editor.AboveBarSpriteReturnSummary}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="2,2,0,8"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,8,0">
                                <TextBlock
                                       Text="{Binding Editor.TooltipSettingsSummary}"
                                       Style="{StaticResource MutedTextStyle}" />
                                <TextBlock
                                       Text="{Binding Editor.TooltipSpriteSummary}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,2,0,0" />
                            </StackPanel>
                            <Button Grid.Row="4" Grid.Column="2"
                                    Content="Attach image"
                                    Command="{Binding Editor.ChooseTooltipImageCommand}"
                                    Padding="12,6"
                                    Margin="10,8,0,0" />
                            <Button Grid.Row="4" Grid.Column="3"
                                    Content="Clear"
                                    Command="{Binding Editor.ClearTooltipImageCommand}"
                                    Padding="12,6"
                                    Margin="8,8,0,0" />
                            <Button Grid.Row="4" Grid.Column="4"
                                    Content="Copy path"
                                    Command="{Binding Editor.CopyTooltipImagePathCommand}"
                                    Padding="12,6"
                                    Margin="8,8,0,0" />
                        </Grid>
                    </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>

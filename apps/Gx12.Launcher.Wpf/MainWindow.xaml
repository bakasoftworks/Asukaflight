<Window x:Class="Gx12.Launcher.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Gx12.Launcher.Wpf.Controls"
        xmlns:models="clr-namespace:Gx12.Launcher.Wpf.Models"
        Title="Asukaflight"
        Width="1360"
        Height="850"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        controls:OptionToolTips.IsEnabled="True">
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style x:Key="RaisedBlockStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource BgRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="0,0,10,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorCheckBoxStyle" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,14,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="29" />
        </Style>

        <Style x:Key="EditorComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource BgRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="31" />
            <Setter Property="Margin" Value="0,0,10,8" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="ToolTipService.ShowDuration" Value="30000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ToolTip="{TemplateBinding ToolTip}"
                                          ToolTipService.ShowOnDisabled="True"
                                          ToolTipService.ShowDuration="30000">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5">
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{StaticResource TextMutedBrush}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Chrome" Property="Background" Value="#15191C" />
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#252B2F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <TextBlock Text="{TemplateBinding SelectionBoxItem}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Margin="10,0,28,0"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       IsHitTestVisible="False" />

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource BgRaisedBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#667176" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource BgRaisedBrush}" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#263036" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#667176" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveStateBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#203330" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="9,5" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Editor.SaveStateKind}" Value="Dirty">
                    <Setter Property="Background" Value="#332C1D" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Editor.SaveStateKind}" Value="Invalid">
                    <Setter Property="Background" Value="#331F21" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RuntimeStateBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#242A2E" />
            <Setter Property="BorderBrush" Value="#3A4247" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RuntimeStateKind}" Value="Accent">
                    <Setter Property="Background" Value="#203330" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RuntimeStateKind}" Value="Warn">
                    <Setter Property="Background" Value="#332C1D" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#242A2E" />
            <Setter Property="BorderBrush" Value="#3A4247" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Default">
                    <Setter Property="Background" Value="#24332F" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Accent">
                    <Setter Property="Background" Value="#203330" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Info">
                    <Setter Property="Background" Value="#202B36" />
                    <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Warn">
                    <Setter Property="Background" Value="#332C1D" />
                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Danger">
                    <Setter Property="Background" Value="#331F21" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="BadgeTemplate" DataType="{x:Type models:ProfileBadge}">
            <Border Style="{StaticResource BadgeBorderStyle}">
                <TextBlock Text="{Binding Label}"
                           FontSize="11"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="NoWrap" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ReleaseCheckTemplate" DataType="{x:Type models:ReleaseCheckItem}">
            <Border Background="#1B2023"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,7,7"
                    MinWidth="210">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Left"
                            Style="{StaticResource BadgeBorderStyle}"
                            MinWidth="74"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding Status}"
                                   FontSize="11"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding Label}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Detail}"
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="11"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" MinWidth="232" />
            <ColumnDefinition Width="*" MinWidth="780" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource PanelStyle}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Profile Library"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ProfileCountSummary}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,2,0,10" />

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search profile names, files, modes, sources, and badges." />
                        <Button Grid.Column="1"
                                Content="X"
                                Command="{Binding ClearSearchCommand}"
                                Margin="6,0,0,0"
                                Padding="0"
                                ToolTip="Clear search." />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <UniformGrid Grid.Row="0" Columns="2">
                            <Button Content="Clone"
                                    Command="{Binding CloneProfileCommand}"
                                    Margin="0,0,5,0"
                                    ToolTip="Create a line-preserving copy of the selected profile." />
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Margin="5,0,0,0" />
                        </UniformGrid>
                        <Button Grid.Row="1"
                                Content="Change folder"
                                Command="{Binding ChangeFolderCommand}"
                                Margin="0,6,0,0"
                                ToolTip="Choose the profile folder used by the launcher." />
                    </Grid>
                </StackPanel>

                <ListBox ItemsSource="{Binding ProfilesView}"
                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProfileSummary}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding DisplayName}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding FileName}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,2,0,7"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap" />
                                <ItemsControl Grid.Row="2"
                                              ItemsSource="{Binding Badges}"
                                              ItemTemplate="{StaticResource BadgeTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock Grid.Row="3"
                                           Text="{Binding SafetySummary}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,2,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{StaticResource BgBaseBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,16,20,12">
                    <DockPanel Margin="0,0,0,18">
                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource SaveStateBadgeStyle}"
                                Margin="16,0,0,0"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding Editor.SaveStateText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="310" />
                        </Border>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding Editor.ProfileName}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedProfileSubheader}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,4,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding SelectedProfile.Badges}"
                                  ItemTemplate="{StaticResource BadgeTemplate}"
                                  Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource RaisedBlockStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Mode" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedProfile.ModeLabel}" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource RaisedBlockStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Frame rate" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedProfile.FrameRateHz}" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource RaisedBlockStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Right stick" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedProfile.RightSourceLabel}" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource RaisedBlockStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Left stick" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedProfile.LeftSourceLabel}" Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource RuntimeStateBadgeStyle}"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="{Binding RuntimeStateLabel}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding RuntimeStateDetail}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,4,0,0"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="{StaticResource BgSurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding RuntimeStatusText}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1"
                                           Text="{Binding TrainerCommandLine}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,6,0,0"
                                           ToolTip="{Binding ConsoleScriptPath}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel Grid.Column="0"
                                       VerticalAlignment="Center">
                                <Button Content="Set default"
                                        Command="{Binding SetDefaultCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,6,6" />
                                <Button Content="Copy path"
                                        Command="{Binding CopyPathCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,6,6" />
                                <Button Content="Copy command"
                                        Command="{Binding CopyTrainerCommandLineCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,6,6" />
                                <Button Content="Copy script"
                                        Command="{Binding CopyConsoleScriptPathCommand}"
                                        Style="{StaticResource CompactButtonStyle}"
                                        Margin="0,0,6,6" />
                            </WrapPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Content="{Binding StartTrainerButtonText}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding StartCompositeTrainerCommand}"
                                        Padding="16,8"
                                        Margin="10,0,8,6"
                                        ToolTip="{Binding TrainerCommandLine}" />
                                <Button Content="{Binding StopRunButtonText}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding StopRunCommand}"
                                        Padding="16,8"
                                        Margin="0,0,0,6" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>

                <TabControl x:Name="WorkspaceTabs" Margin="20,0,20,20">
                    <TabItem Header="Dashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,14,0,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Dashboard" Style="{StaticResource SectionTitleStyle}" />

                            <Border Style="{StaticResource RaisedBlockStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile file" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedProfile.FileName}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Default marker" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DefaultProfileFileName}" Margin="0,8,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Safety keys" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedProfile.SafetySummary}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Gains" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedProfile.GainSummary}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Right tuning" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedProfile.RightTuningSummary}" Margin="0,8,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Left yaw" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedProfile.LeftYawTuningSummary}" Margin="0,8,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
